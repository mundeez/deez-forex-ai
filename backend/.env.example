# =============================================================================
# deez-forex-ai Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
#
# Required: Application will refuse to start without these.
# Optional: Will use sensible defaults if not provided.
# Trading: Only needed if you want live trading (paper mode works without them).
#
# =============================================================================
# 1. DATABASE & CACHE (Required)
# =============================================================================

# PostgreSQL async connection string. Must use asyncpg driver.
# For Docker:   postgresql+asyncpg://forex:YOUR_SECURE_PASSWORD@postgres:5432/deez_forex
# For local:    postgresql+asyncpg://forex:YOUR_SECURE_PASSWORD@localhost:5432/deez_forex
DATABASE_URL=postgresql+asyncpg://forex:YOUR_SECURE_PASSWORD@localhost:5432/deez_forex

# Redis connection string for caching and messaging.
REDIS_URL=redis://localhost:6379/0

# Celery task queue broker (separate Redis DB to avoid conflicts).
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery task result backend.
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# 2. VECTOR DATABASE (Required)
# =============================================================================

# Qdrant URL for market state vector storage and similarity search.
QDRANT_URL=http://localhost:6333

# =============================================================================
# 3. API KEYS (Required for full functionality)
# =============================================================================

# OpenRouter.ai API key for AI trade decisions.
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Model to use. See available models at: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# NewsAPI key for news sentiment analysis.
# Get yours at: https://newsapi.org/register
NEWS_API_KEY=YOUR_NEWSAPI_KEY_HERE

# FRED (Federal Reserve Economic Data) API key for interest rate differentials.
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_KEY_HERE

# =============================================================================
# 4. TRADING CONFIGURATION (Optional - Sensible Defaults)
# =============================================================================

# Max risk per trade as a percentage of account equity (e.g., 2.0 = 2%).
MAX_RISK_PER_TRADE_PCT=2.0

# Max daily loss as a percentage of starting equity (e.g., 5.0 = 5%).
MAX_DAILY_LOSS_PCT=5.0

# Default trading pair (e.g., EURUSD, GBPUSD, USDJPY).
DEFAULT_PAIR=EURUSD

# Strategy mode: scalping | day_trading | swing.
STRATEGY_MODE=scalping

# =============================================================================
# 5. DATA PROVIDER (Optional)
# =============================================================================

# Data provider backend.
#   metaapi  - MetaAPI.cloud (cloud-based MT4/5 bridge, recommended for beginners)
#   mt5_zmq  - Direct ZeroMQ connection to local MT5 terminal (lowest latency)
DATA_PROVIDER=metaapi

# =============================================================================
# 6. META API (Optional - Only for live trading)
# =============================================================================

# MetaAPI.cloud token. Leave empty for paper trading.
META_API_TOKEN=

# MetaAPI.cloud account ID. Leave empty for paper trading.
META_API_ACCOUNT_ID=

# =============================================================================
# 7. MT5 ZERO-MQ BRIDGE (Optional - Only if DATA_PROVIDER=mt5_zmq)
# =============================================================================

# Host of the MT5 ZeroMQ server.
# For Docker Desktop:  host.docker.internal
# For Docker Linux:    172.17.0.1  (or your host IP)
MT5_ZMQ_HOST=host.docker.internal

# Request/Reply port for commands (GET_PRICE, GET_CANDLES, TRADE, CLOSE).
MT5_ZMQ_REQ_PORT=5555

# Publish/Subscribe port for real-time tick data.
MT5_ZMQ_PUB_PORT=5556

# =============================================================================
# 8. CORS / SECURITY (Optional - Production)
# =============================================================================

# Comma-separated list of allowed frontend origins.
# For local development: http://localhost:3000
# For production:        https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# 9. V2 AI TRADING TEAM (Optional - v1 engine works without these)
# =============================================================================

# Decision engine version: v1 (single LLM) | v2 (multi-agent team)
DECISION_ENGINE_VERSION=v1

# Model suite: free | production | extreme | custom
MODEL_SUITE=free

# Per-function model IDs (only used when MODEL_SUITE=custom)
MODEL_TECHNICAL=openai/gpt-oss-120b:free
MODEL_FUNDAMENTAL=meta-llama/llama-3.3-70b-instruct:free
MODEL_SENTIMENT=qwen/qwen3-next-80b-a3b-instruct:free
MODEL_MACRO=deepseek/deepseek-r1:free
MODEL_LEAD=openai/gpt-oss-120b:free
MODEL_VERIFIER=deepseek/deepseek-r1:free

# v2 feature flags
VERIFIER_ENABLED=true
VERIFIER_CAN_VETO=true
DAILY_BIAS_ENABLED=true
EXIT_REEVAL_ENABLED=false
MODEL_PERF_WEIGHTING_ENABLED=false

# Feed configuration
MT5_FEED_DEFAULT=true
PAPER_USES_LIVE_FEED=true
ALLOW_PAPER_FALLBACK=false

# =============================================================================
# 10. APPLICATION SETTINGS (Optional)
# =============================================================================

# Environment: development | staging | production.
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
