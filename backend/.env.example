DATABASE_URL=postgresql+asyncpg://forex:forex_secret@localhost:5432/deez_forex
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
META_API_TOKEN=
META_API_ACCOUNT_ID=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
NEWS_API_KEY=
FRED_API_KEY=
MAX_RISK_PER_TRADE_PCT=2.0
MAX_DAILY_LOSS_PCT=5.0
DEFAULT_PAIR=EURUSD
APP_ENV=development

# Data Provider: metaapi (cloud) or mt5_zmq (desktop)
DATA_PROVIDER=metaapi

# MT5 ZeroMQ Desktop Bridge (only needed if DATA_PROVIDER=mt5_zmq)
MT5_ZMQ_HOST=host.docker.internal
MT5_ZMQ_REQ_PORT=5555
MT5_ZMQ_PUB_PORT=5556
